# LeetCode Exporter Configuration

# LeetCode Credentials
leetcode:
  username: your_email@example.com
  password: your_password

# Output directory for exported solutions
output_path: ./exported_solutions

# Git repository path (where to store solutions locally)
repo_path: ./exported_solutions

# Git remote repository URL (where to push code)
repo_url: https://github.com/your-username/your-repo.git

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
log_level: INFO

# Browser options
headless: false  # Set to false to see the browser window during export
browser: chrome  # Options: chrome, edge, auto
user_data_dir: .selenium_user_data  # Optional: path to Chrome user profile data used by Selenium
profile_dir: Default  # Optional: Chrome profile directory inside user_data_dir
